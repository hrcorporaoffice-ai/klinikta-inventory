# URL Web App Google Apps Script (deployment INVENTORY, BUKAN absensi).
# Ambil dari: Apps Script > Deploy > New deployment > Web app > Web app URL.
# Salin file ini menjadi .env lalu isi nilainya. Di Vercel, set sebagai Environment Variable.
VITE_GAS_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXX/exec
